#
# Common Misconfigurations:
#

# - missing key:
#	WARNING: 'HTTPS_port 127.0.4.1:8443' missing private key in './leaf-rsa.crt'
#	ERROR: Failed to initialize server context with keys from ./leaf-rsa.crt: The request is invalid.
#	FATAL: HTTPS_port 127.0.4.1:8443 initialization error
#https_port 127.0.4.1:8443 tls-cert=./leaf-rsa.crt

# - missing CA cert
#	XXX: ignores the error silently.
https_port 127.0.4.2:8443 tls-generate-host-certificates=off

# - non-CA cert and key
#	WARNING: 'HTTPS_port 127.0.4.3:8443' missing private key in './leaf-rsa.crt'
#	FATAL: No valid signing certificate configured for HTTPS_port 127.0.4.3:8443
#https_port 127.0.4.3:8443 tls-cert=./leaf-rsa.crt tls-generate-host-certificates

