#
# static domain certificate
#
https_port 127.0.1.1:8443 tls-cert=./leaf-rsa.crt tls-key=./leaf-rsa.pkey

https_port 127.0.1.2:8443 tls-cert=./leaf-chain-rsa.pem

https_port 127.0.1.3:8443 tls-cert=./leaf-rsa.crt tls-key=./leaf-rsa.pkey \
	tls-generate-host-certificates=off

https_port 127.0.1.4:8443 tls-cert=./leaf-chain-rsa.pem \
	tls-generate-host-certificates=off

#
# dynamically generated certificates (Squid-3)
#
https_port 127.0.2.1:8443 tls-cert=./ca-root-rsa.crt tls-key=./ca-root-rsa.pkey \
	tls-generate-host-certificates=on

https_port 127.0.2.2:8443 tls-cert=./ca-root-rsa.pem \
	tls-generate-host-certificates=on

https_port 127.0.2.3:8443 tls-cert=./ca-root-rsa.crt tls-key=./ca-root-rsa.pkey \
	tls-generate-host-certificates

https_port 127.0.2.4:8443 tls-cert=./ca-mid-rsa.crt tls-key=./ca-mid-rsa.pkey \
	tls-generate-host-certificates=on

https_port 127.0.2.5:8443 tls-cert=./ca-mid-rsa.pem \
	tls-generate-host-certificates=on

https_port 127.0.2.6:8443 tls-cert=./ca-mid-rsa.crt tls-key=./ca-mid-rsa.pkey \
	tls-generate-host-certificates

https_port 127.0.2.7:8443 tls-cert=./ca-chain-rsa.pem \
	tls-generate-host-certificates

