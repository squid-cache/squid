#
# The following tests check the sparse matrix of (valid) configs:
#
#  1) tls-cert= PEM contents:
#    a) cert only
#    b) full chain
#    c) incomplete chain
#    d) missing
#
#  2) tls-key parameter:
#    a) separate PEM file
#    b) merged with chain PEM file
#
#  3) generate-host-certificates values:
#    a) absent
#    b) "=on"
#    c) "=off"
#    d) no-value
#    e) "=FILE"
#
#
# NOTE:	since Squid-3 cert= can be configured with multiple types
#	of certificate for different purposes the matrix is
#	checked for configurations where cert is a 'static' server
#	certificate, then using a CA certificate.
#

#
# All valid permutations using a static certificate as (1):
#

# case: 1a, 2a, 3a
https_port 127.0.1.1:8443 tls-cert=./leaf-rsa.crt tls-key=./leaf-rsa.pkey
# case: 1b, 2a, 3a
https_port 127.0.1.2:8443 tls-cert=./leaf-chain-rsa.pem tls-key=./leaf-rsa.pkey
# case: 1c, 2a, 3a duplicate of (1a, 2a, 3a)
# case: 1d, 2a, 3a invalid
# case: 1a, 2b, 3a N/A (requires cafile=/capath= options)
# case: 1b, 2b, 3a
https_port 127.0.1.2:8443 tls-cert=./leaf-chain-rsa.pem
# case: 1c, 2b, 3a ??
# case: 1d, 2b, 3a N/A (requires cafile=/capath= options)

# case: 1a, 2a, 3b invalid
# case: 1b, 2a, 3b invalid
# case: 1c, 2a, 3b invalid
# case: 1d, 2a, 3b invalid
# case: 1a, 2b, 3b invalid
# case: 1b, 2b, 3b invalid
# case: 1c, 2b, 3b invalid
# case: 1d, 2b, 3b invalid

# case: 1a, 2a, 3c
https_port 127.0.1.3:8443 tls-cert=./leaf-rsa.crt tls-key=./leaf-rsa.pkey \
	tls-generate-host-certificates=off
# case: 1b, 2a, 3c
https_port 127.0.1.2:8443 tls-cert=./leaf-chain-rsa.pem tls-key=./leaf-rsa.pkey
# case: 1c, 2a, 3c ???
# case: 1d, 2a, 3c invalid
# case: 1a, 2b, 3c N/A (requires cafile=/capath= options)
# case: 1b, 2b, 3c
https_port 127.0.1.4:8443 tls-cert=./leaf-chain-rsa.pem \
	tls-generate-host-certificates=off
# case: 1c, 2b, 3c ????
# case: 1d, 2b, 3c invalid

# case: 1a, 2a, 3d invalid
# case: 1b, 2a, 3d invalid
# case: 1c, 2a, 3d invalid
# case: 1d, 2a, 3d invalid
# case: 1a, 2b, 3d invalid
# case: 1b, 2b, 3d invalid
# case: 1c, 2b, 3d invalid
# case: 1d, 2b, 3d invalid

# case: 1a, 2a, 3e invalid
# case: 1b, 2a, 3e invalid
# case: 1c, 2a, 3e invalid
# case: 1d, 2a, 3e invalid
# case: 1a, 2b, 3e invalid
# case: 1b, 2b, 3e invalid
# case: 1c, 2b, 3e invalid
# case: 1d, 2b, 3e invalid

#
# All valid permutations using a CA certificate as (1):
#  Squid-3 permutations:
#

# case: 1a, 2a, 3a invalid
# case: 1b, 2a, 3a invalid
# case: 1c, 2a, 3a N/A duplicate of (1a, 2a, 3a)
# case: 1d, 2b, 3e invalid
# case: 1a, 2b, 3a invalid
# case: 1b, 2b, 3a invalid
# case: 1c, 2b, 3a invalid
# case: 1d, 2b, 3a invalid

# case: 1a, 2a, 3b
https_port 127.0.2.4:8443 tls-cert=./ca-mid-rsa.crt tls-key=./ca-mid-rsa.pkey \
	tls-generate-host-certificates=on
https_port 127.0.2.1:8443 tls-cert=./ca-root-rsa.crt tls-key=./ca-root-rsa.pkey \
	tls-generate-host-certificates=on
# case: 1b, 2a, 3b
https_port 127.0.1.2:8443 tls-cert=./leaf-chain-rsa.pem tls-key=./leaf-rsa.pkey \
	tls-generate-host-certificates=on
# case: 1c, 2a, 3b invalid
# case: 1a, 2b, 3b N/A (requires cafile=/capath= options)
# case: 1b, 2b, 3b
https_port 127.0.2.7:8443 tls-cert=./ca-chain-rsa.pem \
	tls-generate-host-certificates=on
# case: 1c, 2b, 3b
https_port 127.0.2.5:8443 tls-cert=./ca-mid-rsa.pem \
	tls-generate-host-certificates=on
# case: 1d, 2b, 3b invalid
https_port 127.0.2.2:8443 tls-cert=./ca-root-rsa.pem \
	tls-generate-host-certificates=on

